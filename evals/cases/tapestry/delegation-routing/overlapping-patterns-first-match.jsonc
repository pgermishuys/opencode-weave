{
  "id": "tapestry-delegation-routing-overlapping-patterns-first-match",
  "title": "Tapestry uses first-match precedence when category patterns overlap",
  "description": "Checks that when task files match multiple configured category patterns, Tapestry routes to the first matching category in config declaration order.",
  "phase": "experimental",
  "tags": ["experimental", "tapestry", "delegation-routing", "category", "overlap", "precedence"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "tapestry",
    "variant": {
      "categories": {
        "frontend": {
          "patterns": ["*.tsx", "*.css", "src/components/**"]
        },
        "dashboard": {
          "patterns": ["src/components/dashboard/**", "*.tsx"]
        }
      }
    }
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "You are executing /start-work. The plan has one unchecked task:\n\n- [ ] Task 2/5: Update dashboard widget implementation\n  **Files**: src/components/dashboard/Widget.tsx, src/components/dashboard/Widget.css\n  **What**: Update the dashboard widget behavior and styling\n  **Acceptance**: Widget renders the updated behavior and CSS styling correctly.\n\nUse first-match precedence based on config declaration order. Which shuttle agent would you use to delegate this task and why? Answer in one sentence, name only the chosen shuttle agent, and do not mention any other shuttle agents by name."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedAnyOf": ["shuttle-frontend", "route to shuttle-frontend", "first matching category", "first match in config order", "frontend is declared first", "overlapping patterns", "config declaration order", "frontend"],
      "forbiddenContains": ["shuttle-dashboard", "route to shuttle-dashboard", "dashboard is more specific so use dashboard", "generic shuttle", "plain shuttle"]
    }
  ]
}
