{
  "id": "route-to-spindle-research",
  "title": "Routes to Spindle for external research asks",
  "description": "Verifies that Loom delegates external documentation research (e.g. Stripe API best practices) to Spindle rather than answering from its own knowledge.",
  "phase": "routing",
  "tags": ["routing", "loom"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "Research how the Stripe API handles idempotency keys and summarize the best practices from their docs."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedContains": ["spindle"],
      "forbiddenContains": ["implement directly", "I'll handle this myself"]
    }
  ]
}
