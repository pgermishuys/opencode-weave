{
  "id": "route-to-pattern-planning",
  "title": "Routes to Pattern for complex implementation planning",
  "description": "Verifies that Loom delegates complex multi-file feature work (data models, APIs, tests) to Pattern for structured planning rather than implementing directly.",
  "phase": "routing",
  "tags": ["routing", "loom"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "Implement a multi-file feature with data model updates, API changes, and integration tests."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedContains": ["pattern", "/start-work"],
      "forbiddenContains": ["I will implement this directly"]
    }
  ]
}
