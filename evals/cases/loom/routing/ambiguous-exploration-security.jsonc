{
  // Gray zone: could be Thread (exploration) or Warp (security) — delegation should happen
  "id": "ambiguous-exploration-security",
  "title": "Delegates ambiguous exploration+security asks",
  "description": "Gray zone: request could go to Thread (exploration) or Warp (security). Verifies that Loom delegates to at least one agent rather than handling the auth security scan itself.",
  "phase": "routing",
  "tags": ["routing", "loom", "ambiguous"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "Scan the authentication module for potential security vulnerabilities and summarize what you find."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "forbiddenContains": ["I'll handle this myself", "implement directly"]
    }
  ]
}
