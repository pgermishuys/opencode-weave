{
  // Two-phase task: research (Spindle) then planning (Pattern) — delegation should happen
  "id": "ambiguous-research-planning",
  "title": "Delegates ambiguous research+planning asks",
  "description": "Two-phase task: research (Spindle) then planning (Pattern). Verifies that Loom delegates rather than attempting to research OAuth2 PKCE and plan the implementation itself.",
  "phase": "routing",
  "tags": ["routing", "loom", "ambiguous"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "Research how other projects implement OAuth2 PKCE flow, then create a plan for adding it to our app."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "forbiddenContains": ["I'll handle this myself", "implement directly"]
    }
  ]
}
