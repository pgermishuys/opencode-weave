{
  // Harder shuttle routing — does NOT use the magic phrase "category-specific specialized work"
  "id": "route-to-shuttle-implicit",
  "title": "Routes to Shuttle without explicit prompt-mirroring cues",
  "phase": "routing",
  "tags": ["routing", "loom"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "We have a product catalog domain that needs GraphQL schema generation — types, resolvers, and input validation. Please delegate to the right specialist agent for this domain work."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedContains": ["shuttle"],
      "forbiddenContains": ["I will implement this directly"]
    }
  ]
}
