{
  // Single-file, single-line fix — Loom should handle directly without delegation
  "id": "self-handle-single-file-fix",
  "title": "Self-handles single-file fixes without delegation",
  "description": "Verifies that Loom handles trivial single-file fixes (e.g. fixing a typo on one line) directly without delegating to Pattern, Shuttle, or other agents.",
  "phase": "routing",
  "tags": ["routing", "loom", "self-handle"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "There's a typo in src/utils/format.ts on line 42 — it says 'formated' instead of 'formatted'. Fix it."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "forbiddenContains": ["pattern", "spindle", "warp", "weft", "shuttle", "delegate to"]
    }
  ]
}
